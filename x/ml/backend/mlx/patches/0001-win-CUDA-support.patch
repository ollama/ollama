+// Runtime kernel selector that uses dtype enum values directly instead of
+// template type matching This avoids MSVC issues with type deduction through
+// nested lambdas
+void* get_copy_kernel_by_dtype(
+    Dtype in_dtype,
+    Dtype out_dtype,
+    CopyType ctype,
+    bool large) {
