+DECL_COPY_KERNELS(int32_t, __half, i32, half, 4)
+DECL_COPY_KERNELS(__half, int32_t, half, i32, 8)
+DECL_COPY_KERNELS(int32_t, __nv_bfloat16, i32, bf16, 4)
+DECL_COPY_KERNELS(__nv_bfloat16, int32_t, bf16, i32, 8)
