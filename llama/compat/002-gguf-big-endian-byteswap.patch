+    // Whether the host is big-endian. GGUF files are always little-endian on disk.
+    mutable bool need_bswap;
+
+    template <typename T>
+    static T bswap_if_needed(T v, bool do_bswap) {
+        if (!do_bswap || sizeof(T) == 1) { return v; }
+        uint8_t buf[sizeof(T)];
+        memcpy(buf, &v, sizeof(T));
+        for (size_t lo = 0, hi = sizeof(T) - 1; lo < hi; ++lo, --hi) {
+            uint8_t tmp = buf[lo]; buf[lo] = buf[hi]; buf[hi] = tmp;
+        }
+        memcpy(&v, buf, sizeof(T));
+        return v;
+    }
