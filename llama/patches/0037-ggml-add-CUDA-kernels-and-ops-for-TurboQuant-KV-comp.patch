+            __syncthreads();
+            for (int stride = half_block; stride > 0; stride >>= 1) {
+                if (threadIdx.x < stride) s_reduce[threadIdx.x] += s_reduce[threadIdx.x + stride];
+                __syncthreads();
+            }
+            float s_eden = (s_reduce[0] > 1e-12f && eden_num > 0.0f) ? (eden_num / s_reduce[0]) : regScale;
