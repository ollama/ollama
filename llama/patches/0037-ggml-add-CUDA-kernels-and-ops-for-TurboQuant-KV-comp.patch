+            for (int r = threadIdx.x; r < regularCount; r += block_size) {
+                int orig = s_reg_pos[r];
+                float v = (regScale > 0.0f) ? ((s_k[orig] - regMean) / regScale) : 0.0f;
+                int idx = 0;
+                for (int b = 0; b < numBoundaries; b++) { if (v >= boundaries[b]) idx++; }
