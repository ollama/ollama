+            }
+            __syncthreads();
+        }
+        if (threadIdx.x == 0) {
+            scales_out[cell * numKVHeads + head] = regScale;
+        }
+        __syncthreads();
+    }
+
+    // Step 7: Pack regular bits into packed_out.
+    // Per-head stride is padded up to a 4-byte multiple so atomicOr on
