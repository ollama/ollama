 ggml/src/ggml-metal/ggml-metal-device.h   |   13 +
 ggml/src/ggml-metal/ggml-metal-device.m   |    7 +
 ggml/src/ggml-metal/ggml-metal-impl.h     |   95 +
 ggml/src/ggml-metal/ggml-metal-ops.cpp    |  670 +++++
 ggml/src/ggml-metal/ggml-metal-ops.h      |    8 +
 ggml/src/ggml-metal/ggml-metal.metal      | 2721 +++++++++++++++++++++
 7 files changed, 3536 insertions(+)

