+    }
+
+    size_t alloc_size() override {
+        return total_alloc_size;
+    }
 };
 
 // pool with virtual memory
@@ -491,6 +512,8 @@ struct ggml_cuda_pool_vmm : public ggml_cuda_pool {
     static const size_t CUDA_POOL_VMM_MAX_SIZE = 1ull << 35; // 32 GB
 
