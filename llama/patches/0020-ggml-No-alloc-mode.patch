@@ -418,6 +422,12 @@ struct ggml_cuda_pool_leg : public ggml_cuda_pool {
     }
 
     void * alloc(size_t size, size_t * actual_size) override {
+        if (!allocate) {
+            size_t look_ahead_size = CUDA_ALIGNMENT * ((size + CUDA_ALIGNMENT - 1) / CUDA_ALIGNMENT);
+            *actual_size = look_ahead_size;
+            total_alloc_size += look_ahead_size;
+            return (void *)(uintptr_t)CUDA_ALIGNMENT;
+        }
 #ifdef DEBUG_CUDA_MALLOC
         int nnz = 0;
         size_t max_size = 0;
@@ -470,6 +480,9 @@ struct ggml_cuda_pool_leg : public ggml_cuda_pool {
     }
 
