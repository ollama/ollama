             if (b.ptr == nullptr) {
@@ -483,6 +496,14 @@ struct ggml_cuda_pool_leg : public ggml_cuda_pool {
         CUDA_CHECK(cudaFree(ptr));
         pool_size -= size;
     }
+
+    bool alloc_memory() override {
