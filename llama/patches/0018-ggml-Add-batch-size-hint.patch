diff --git a/ggml/include/ggml-backend.h b/ggml/include/ggml-backend.h
index adf375420..04f4973ff 100644
--- a/ggml/include/ggml-backend.h
+++ b/ggml/include/ggml-backend.h
@@ -98,7 +98,7 @@ extern "C" {
 
