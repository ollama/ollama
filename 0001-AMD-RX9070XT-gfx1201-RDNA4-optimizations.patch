+#define CHECK_HIP(cmd) do { hipError_t e = cmd; if (e != hipSuccess) { \
+    fprintf(stderr, "HIP error %s at %s:%d\n", hipGetErrorString(e), __FILE__, __LINE__); \
+    return; } } while(0)
+
+#define CHECK_HIP_RET(cmd) do { hipError_t e = cmd; if (e != hipSuccess) { \
+    fprintf(stderr, "HIP error %s at %s:%d\n", hipGetErrorString(e), __FILE__, __LINE__); \
