+// ============================================================================
+// ggml_hip_ext.cpp — Complete ROCm 7.x Extension Library for OLLaMA/llama.cpp
+// Target: gfx1201 (RX 9070 XT) + other RDNA3/CDNA/RDNA4
+// Compile: hipcc -O3 -ffast-math -fPIC -shared -o libggml_hip_ext.so ggml_hip_ext.cpp
