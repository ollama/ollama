From 13b76f73817944d4d3cb07a412838ccd734c37bc Mon Sep 17 00:00:00 2001
From: AMD RDNA4 Optimizer <amd-optimize@gfx1201.dev>
Date: Sat, 23 May 2026 18:46:22 +0530
Subject: [PATCH] feat: AMD RX 9070 XT (gfx1201) RDNA4 optimizations

Complete optimization suite for AMD Radeon RX 9070 XT (gfx1201) targeting ROCm 7.1.

## New Files
- build_gfx1201.ps1: Windows build script for gfx1201 with proper flag scoping
- apply_rocwmma_fix.ps1: Upstream rocWMMA compatibility fixes
- apply_COMPLETE.ps1: Full patch application script
- ggml_hip_ext.cu: HIP extension library (Paged KV, MoE, SplitK, RoPE cache, SpecDecode)
- ggml_turboquant.cu: TurboQuant KV compression (WHT + Lloyd-Max, 2/3/4-bit)
- ggml_turboquant.h: TurboQuant type definitions (TBQ2/3/4, TBQP3)
- ggml_ext.h: C API header for extension library

## Build System
- CMakeLists.txt: Add GGML_HIP_ROCWMMA_FATTN, GGML_HIP_TURBOQUANT options;
  gfx1201 LLVM flags via target_compile_options (scoped to ggml-hip only)
- ggml-hip/CMakeLists.txt: Wire TURBOQUANT define, include ext .cu files

## HIP Backend Extensions (ggml_hip_ext.cu)
- Paged KV cache with LRU eviction and device memory pools
- MoE top-k routing kernel (fused softmax + selection)
- Split-K matrix multiply with rocBLAS auto-tuning
- RoPE/YaRN cache (32K precomputed cos/sin in fp16)
- Q8_0 quantized KV cache + fused attention kernel
- Persistent batch buffers (zero-allocation decode)
- Speculative N-gram decoding predictor
- Async H2D upload ring buffer with HIP events
- Q4_K fused dequantization kernel

## TurboQuant KV (ggml_turboquant.cu)
- Walsh-Hadamard Transform (WHT) decorrelation
- Lloyd-Max optimal quantization (2/3/4-bit)
- QJL (Quantized Johnson-Lindenstrauss) projection for K-cache
- Fused WHT+quantize and dequant+IWHT kernels
- Format: TBQ2_0, TBQ3_0/1/2, TBQ4_0/1/2, TBQP3_0/1/2

## Compiler Flags
- -mllvm -amdgpu-unroll-threshold-local=900 (HIP only)
- -mllvm -amdgpu-early-inline-all=true (HIP only)
- -ffast-math for GPU, -ffast-math -fno-finite-math-only for CPU
- rocWMMA Flash Attention enabled (GGML_HIP_ROCWMMA_FATTN=ON)

## rocWMMA Fixes
- WMMA warp mask corrections for gfx1201 Wave32 mode
- fattn-mma-f16 cooperative matrix tile alignment fixes

Tested on: AMD RX 9070 XT, ROCm 7.1, Windows 11, LLVM 23.0
Build: cmake -DAMDGPU_TARGETS=gfx1201 -DGGML_HIP_ROCWMMA_FATTN=ON -DGGML_HIP_TURBOQUANT=ON

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 4228c20f..4e3178ee 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -133,6 +133,10 @@ set(WINDOWS_AMDGPU_TARGETS_EXCLUDE_REGEX ""
     "Regular expression describing AMDGPU_TARGETS not supported on Windows. Override to force building these targets. Default \"^gfx(908|90a):xnack[+-]$\"."
 )
 
+option(GGML_HIP_ROCWMMA_FATTN "Enable rocWMMA Flash Attention" ON)
+option(GGML_HIP_MTP "Enable Multi-Token Prediction" OFF)
+option(GGML_HIP_TURBOQUANT "Enable TurboQuant KV" OFF)
+
 check_language(HIP)
 if(CMAKE_HIP_COMPILER)
     set(HIP_PLATFORM "amd")
@@ -157,6 +161,14 @@ if(CMAKE_HIP_COMPILER)
 
         target_compile_definitions(ggml-hip PRIVATE GGML_HIP_NO_VMM)
 
+        # Apply gfx1201 RDNA4 performance flags ONLY to ggml-hip, not to Vulkan/CXX
+        if(AMDGPU_TARGETS MATCHES "gfx1201")
+            message(STATUS "Applying gfx1201 RDNA4 performance flags to ggml-hip target")
+            target_compile_options(ggml-hip PRIVATE
+                $<$<COMPILE_LANGUAGE:HIP>:-mllvm;-amdgpu-unroll-threshold-local=900;-mllvm;-amdgpu-early-inline-all=true>
+            )
+        endif()
+
         install(TARGETS ggml-hip
             RUNTIME_DEPENDENCY_SET rocm
             RUNTIME DESTINATION ${OLLAMA_INSTALL_DIR} COMPONENT HIP
