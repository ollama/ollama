# Maintainer: Your Name <youremail@example.com>
pkgname=ollama-turboquant-git
pkgver=0.30.8.r6.g2efa8c6
pkgrel=1
pkgdesc='Create, run and share large language models (LLMs) - TurboQuant fork'
arch=('x86_64')
url='https://github.com/nomadstar/ollama'
license=('MIT')
depends=('libgcc' 'libstdc++' 'glibc')
makedepends=('cmake' 'git' 'go')
provides=('ollama')
conflicts=('ollama')
options=('!lto')
source=("git+https://github.com/nomadstar/ollama.git#branch=turboquant"
        "ollama.service"
        "sysusers.conf"
        "tmpfiles.conf")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

# Detección de hardware y backend interactivo
_has_amd=0
_has_nvidia=0
if lspci | grep -iE 'vga|3d|display' | grep -qiE '\b(amd|ati|advanced micro devices)\b'; then _has_amd=1; fi
if lspci | grep -iE 'vga|3d|display' | grep -qi 'nvidia'; then _has_nvidia=1; fi

if [ "$_has_amd" -eq 1 ]; then _autofallback="rocm"
elif [ "$_has_nvidia" -eq 1 ]; then _autofallback="cuda"
else _autofallback="vulkan"; fi

_backend="${OLLAMA_BACKEND:-}"

# Evitar prompts si no hay TTY o si se está evaluando via makepkg/AUR helpers silenciosamente
if [ -z "$_backend" ] && [ -t 0 ] && [ -z "$MAKEPKG_SOURCED" ] && [[ ! "$(ps -o comm= -p $PPID)" =~ "yay|paru" ]]; then
  # Para evitar preguntar múltiples veces cuando makepkg hace "source", usamos un archivo temporal
  _prompt_cache="/tmp/ollama_pkgbuild_choice_$UID"
  if [ -f "$_prompt_cache" ] && [ $(( $(date +%s) - $(stat -c %Y "$_prompt_cache") )) -lt 60 ]; then
    _backend=$(cat "$_prompt_cache")
  else
    echo "==================================================" >&2
    echo "Ollama TurboQuant - Detección de Tarjeta Gráfica" >&2
    echo "==================================================" >&2
    echo "Por favor, elige el backend de aceleración:" >&2
    echo "  0) Autofallback (Recomendado: $_autofallback)" >&2
    if [ "$_has_amd" -eq 1 ]; then echo "  1) ROCm" >&2; fi
    if [ "$_has_nvidia" -eq 1 ]; then echo "  2) CUDA" >&2; fi
    echo "  3) Vulkan" >&2
    echo "==================================================" >&2
    read -r -p "Tu elección [0]: " _choice < /dev/tty
    
    case "$_choice" in
      1) _backend="rocm" ;;
      2) _backend="cuda" ;;
      3) _backend="vulkan" ;;
      *) _backend="$_autofallback" ;;
    esac
    echo "$_backend" > "$_prompt_cache"
  fi
fi

# Si no se pudo asignar interactivamente o el usuario ignoró, forzar fallback
if [ -z "$_backend" ]; then
  _backend="$_autofallback"
fi

if [ "$_backend" = "rocm" ]; then
  pkgdesc="$pkgdesc (ROCm)"
  makedepends+=('rocm-hip-sdk' 'rocm-opencl-sdk')
  depends+=('rocm-hip-runtime')
elif [ "$_backend" = "cuda" ]; then
  pkgdesc="$pkgdesc (CUDA)"
  makedepends+=('cuda')
  depends+=('cuda')
else
  _backend="vulkan"
  pkgdesc="$pkgdesc (Vulkan)"
  makedepends+=('vulkan-headers')
  depends+=('vulkan-driver' 'vulkan-icd-loader')
fi

pkgver() {
  cd "$srcdir/ollama"
  git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g' | sed 's/^v//'
}

prepare() {
  cd "$srcdir/ollama"
  # Limpiar cualquier comentario en la versión que rompa cmake FetchContent
  sed -i 's/ .*//' LLAMA_CPP_VERSION
  # Corregir la URL del repositorio remoto en cmake/local.cmake
  sed -i 's|https://github.com/ggml-org/llama.cpp.git|https://github.com/nomadstar/llama-cpp-turboquant.git|' cmake/local.cmake
  # Eliminar parche y código fuente roto de laguna que no compila en turboquant
  rm -rf llama/compat/models
  
  # Eliminar flags no soportados por el fork antiguo
  sed -i -e '/--no-log-prefix/d' -e '/--no-log-timestamps/d' llm/llama_server.go

  # Añadir stubs débiles (weak symbols) para las funciones CUDA de turboquant
  # de modo que el build de CPU local pueda enlazar libllama.so correctamente.
  cat << 'EOF' > llama/compat/turboquant-stubs.cpp
#include <cstdint>
#include <cstddef>

extern "C" {
    __attribute__((weak)) float g_innerq_scale_inv_host[128] = {0};
    __attribute__((weak)) int turbo_innerq_needs_tensor_update(void) { return 0; }
    __attribute__((weak)) void turbo_innerq_mark_tensor_updated(void) {}

    __attribute__((weak)) void * triattention_gpu_init(const void * config, const void * head_calibs, const float * omega, const float * freq_scale_sq, const float * offsets, void * stream) { return nullptr; }
    __attribute__((weak)) void triattention_gpu_score_head(void * state, const void * k_data_dev, uint64_t n_embd_k_gqa, size_t row_bytes, uint32_t kv_head_idx, uint32_t head_calib_idx, const uint32_t * cell_indices_dev, const int32_t * positions_dev, uint32_t n_cells, int64_t round_start, int agg_mode, float * scores_dev, void * stream) {}
    __attribute__((weak)) void triattention_gpu_scores_to_host(float * scores_host, const float * scores_dev, uint32_t n_cells, void * stream) {}
    __attribute__((weak)) void triattention_gpu_upload_cells(uint32_t ** cell_indices_dev, int32_t ** positions_dev, const uint32_t * cell_indices_host, const int32_t * positions_host, uint32_t n_cells, void * stream) {}
    __attribute__((weak)) float * triattention_gpu_alloc_scores(uint32_t n_cells, void * stream) { return nullptr; }
    __attribute__((weak)) void triattention_gpu_free_dev(void * ptr) {}
    __attribute__((weak)) void triattention_gpu_free(void * state) {}
}
EOF
  sed -i '/llama-ollama-compat-util.cpp"/a \    "${_compat_dir}/turboquant-stubs.cpp"' llama/compat/compat.cmake
}

build() {
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOPATH="${srcdir}"
  export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw -ldflags=-linkmode=external"

  cd ollama

  # Remove the runtime dependencies from installation so CMake doesn't install
  # lots of system dependencies into the target path.
  sed -i 's/PRE_INCLUDE_REGEXES.*/PRE_INCLUDE_REGEXES = ""/' CMakeLists.txt

  local cmake_base_options=(
    -W no-dev
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
  )

  local repo_root="$startdir/../.."
  local force_compile="${OLLAMA_FORCE_COMPILE:-0}"
  
  if [ "$force_compile" -ne 1 ] && [ -d "$repo_root/build/llama-server-local/bin" ]; then
    echo "========================================================"
    echo "¡Librerías C/C++ precompiladas encontradas en la raíz!"
    echo "Copiando $repo_root/build para omitir compilación CMake..."
    echo "========================================================"
    cp -a "$repo_root/build" .
  else
    if [ "$force_compile" -eq 1 ]; then
      echo "OLLAMA_FORCE_COMPILE=1 detectado. Forzando compilación limpia de CMake..."
    fi
    if [ "$_backend" = "rocm" ]; then
      cmake -B build "${cmake_base_options[@]}" -D GGML_HIP=ON -D AMDGPU_TARGETS=native
    elif [ "$_backend" = "cuda" ]; then
      cmake -B build "${cmake_base_options[@]}" -D GGML_CUDA=ON -D CMAKE_CUDA_ARCHITECTURES=native
    else
      cmake -B build "${cmake_base_options[@]}" -D GGML_VULKAN=ON
    fi
    cmake --build build -j$(nproc)
  fi

  if [ "$force_compile" -ne 1 ] && [ -x "$repo_root/ollama" ]; then
    echo "========================================================"
    echo "¡Binario Go de Ollama encontrado en la raíz!"
    echo "Copiando $repo_root/ollama para omitir Go build..."
    echo "========================================================"
    cp -a "$repo_root/ollama" .
  else
    if [ "$force_compile" -eq 1 ]; then
      echo "OLLAMA_FORCE_COMPILE=1 detectado. Forzando compilación limpia de Go..."
    fi
    go build .
  fi
  
  DESTDIR="$srcdir/staging-install" cmake --install build
}

package() {
  cd "$srcdir/ollama"
  
  # Install binary and state directory
  install -Dm755 ollama "$pkgdir/usr/bin/ollama"
  install -dm755 "$pkgdir/var/lib/ollama"
  
  # Install generated payloads
  mkdir -p "$pkgdir/usr/lib/ollama"
  if [ -d "$srcdir/staging-install/usr/lib/ollama" ]; then
    cp -dr --no-preserve=ownership "$srcdir/staging-install/usr/lib/ollama/"* "$pkgdir/usr/lib/ollama/"
  elif [ -d "$srcdir/staging-install/usr/local/lib/ollama" ]; then
    cp -dr --no-preserve=ownership "$srcdir/staging-install/usr/local/lib/ollama/"* "$pkgdir/usr/lib/ollama/"
  fi
  
  # Copiar la librería compartida generada según el backend
  if [ "$_backend" = "rocm" ] && [ -f "build/llama-server-local/bin/libggml-hip.so" ]; then
    cp build/llama-server-local/bin/libggml-hip.so "$pkgdir/usr/lib/ollama/"
  elif [ "$_backend" = "cuda" ] && [ -f "build/llama-server-local/bin/libggml-cuda.so" ]; then
    cp build/llama-server-local/bin/libggml-cuda.so "$pkgdir/usr/lib/ollama/"
  elif [ "$_backend" = "vulkan" ] && [ -f "build/llama-server-local/bin/libggml-vulkan.so" ]; then
    cp build/llama-server-local/bin/libggml-vulkan.so "$pkgdir/usr/lib/ollama/"
  fi

  # Install system files
  install -Dm644 "$srcdir/ollama.service" "$pkgdir/usr/lib/systemd/system/ollama.service"
  install -Dm644 "$srcdir/sysusers.conf" "$pkgdir/usr/lib/sysusers.d/ollama.conf"
  install -Dm644 "$srcdir/tmpfiles.conf" "$pkgdir/usr/lib/tmpfiles.d/ollama.conf"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  ln -s /var/lib/ollama "$pkgdir/usr/share/ollama"
}
