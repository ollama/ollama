# Maintainer: Your Name <youremail@example.com>
pkgbase=ollama-turboquant-git
pkgname=('ollama-turboquant-cuda-git' 'ollama-turboquant-vulkan-git' 'ollama-turboquant-rocm-git')
pkgver=0.30.8.r4.gd66fc63
pkgrel=1
pkgdesc='Create, run and share large language models (LLMs) - TurboQuant fork'
arch=('x86_64')
url='https://github.com/nomadstar/ollama'
license=('MIT')
depends=('libgcc' 'libstdc++' 'glibc')
makedepends=('cmake' 'git' 'go' 'cuda' 'vulkan-headers' 'rocm-hip-sdk' 'rocm-opencl-sdk')
options=('!lto')
source=("git+https://github.com/nomadstar/ollama.git#branch=turboquant"
        "ollama.service"
        "sysusers.conf"
        "tmpfiles.conf")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

pkgver() {
  cd "$srcdir/ollama"
  git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g' | sed 's/^v//'
}

prepare() {
  cd "$srcdir/ollama"
  # Limpiar cualquier comentario en la versión que rompa cmake FetchContent
  sed -i 's/ .*//' LLAMA_CPP_VERSION
  # Corregir la URL del repositorio remoto en cmake/local.cmake
  sed -i 's|https://github.com/ggml-org/llama.cpp.git|https://github.com/nomadstar/llama-cpp-turboquant.git|' cmake/local.cmake
  # Eliminar parche y código fuente roto de laguna que no compila en turboquant
  rm -rf llama/compat/models
  
  # Eliminar flags no soportados por el fork antiguo
  sed -i -e '/--no-log-prefix/d' -e '/--no-log-timestamps/d' llm/llama_server.go

  # Añadir stubs débiles (weak symbols) para las funciones CUDA de turboquant
  # de modo que el build de CPU local pueda enlazar libllama.so correctamente.
  cat << 'EOF' > llama/compat/turboquant-stubs.cpp
#include <cstdint>
#include <cstddef>

extern "C" {
    __attribute__((weak)) float g_innerq_scale_inv_host[128] = {0};
    __attribute__((weak)) int turbo_innerq_needs_tensor_update(void) { return 0; }
    __attribute__((weak)) void turbo_innerq_mark_tensor_updated(void) {}

    __attribute__((weak)) void * triattention_gpu_init(const void * config, const void * head_calibs, const float * omega, const float * freq_scale_sq, const float * offsets, void * stream) { return nullptr; }
    __attribute__((weak)) void triattention_gpu_score_head(void * state, const void * k_data_dev, uint64_t n_embd_k_gqa, size_t row_bytes, uint32_t kv_head_idx, uint32_t head_calib_idx, const uint32_t * cell_indices_dev, const int32_t * positions_dev, uint32_t n_cells, int64_t round_start, int agg_mode, float * scores_dev, void * stream) {}
    __attribute__((weak)) void triattention_gpu_scores_to_host(float * scores_host, const float * scores_dev, uint32_t n_cells, void * stream) {}
    __attribute__((weak)) void triattention_gpu_upload_cells(uint32_t ** cell_indices_dev, int32_t ** positions_dev, const uint32_t * cell_indices_host, const int32_t * positions_host, uint32_t n_cells, void * stream) {}
    __attribute__((weak)) float * triattention_gpu_alloc_scores(uint32_t n_cells, void * stream) { return nullptr; }
    __attribute__((weak)) void triattention_gpu_free_dev(void * ptr) {}
    __attribute__((weak)) void triattention_gpu_free(void * state) {}
}
EOF
  sed -i '/llama-ollama-compat-util.cpp"/a \    "${_compat_dir}/turboquant-stubs.cpp"' llama/compat/compat.cmake
}

build() {
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOPATH="${srcdir}"
  export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw -ldflags=-linkmode=external"

  cd ollama

  # Remove the runtime dependencies from installation so CMake doesn't install
  # lots of system dependencies into the target path.
  sed -i 's/PRE_INCLUDE_REGEXES.*/PRE_INCLUDE_REGEXES = ""/' CMakeLists.txt

  local cmake_base_options=(
    -W no-dev
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
  )

  # Build CUDA (with auto native architecture)
  cmake -B build-cuda "${cmake_base_options[@]}" -D GGML_CUDA=ON -D CMAKE_CUDA_ARCHITECTURES=native
  cmake --build build-cuda -j$(nproc)

  # Build Vulkan
  cmake -B build-vulkan "${cmake_base_options[@]}" -D GGML_VULKAN=ON
  cmake --build build-vulkan -j$(nproc)

  # Build ROCm (HIP) (with auto native architecture)
  # Usar un compilador alternativo si fuera necesario, comúnmente CMAKE_CXX_COMPILER=hipcc, 
  # pero GGML_HIP=ON suele bastar.
  cmake -B build-rocm "${cmake_base_options[@]}" -D GGML_HIP=ON -D AMDGPU_TARGETS=native
  cmake --build build-rocm -j$(nproc)

  go build .
}

_package_common() {
  cd "$srcdir/ollama"
  install -Dm755 ollama "$pkgdir/usr/bin/ollama"
  install -dm755 "$pkgdir/var/lib/ollama"
  install -Dm644 "$srcdir/ollama.service" "$pkgdir/usr/lib/systemd/system/ollama.service"
  install -Dm644 "$srcdir/sysusers.conf" "$pkgdir/usr/lib/sysusers.d/ollama.conf"
  install -Dm644 "$srcdir/tmpfiles.conf" "$pkgdir/usr/lib/tmpfiles.d/ollama.conf"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  ln -s /var/lib/ollama "$pkgdir/usr/share/ollama"
}

package_ollama-turboquant-cuda-git() {
  pkgdesc="Create, run and share large language models (LLMs) - TurboQuant fork with CUDA"
  depends+=('cuda')
  provides=('ollama' 'ollama-turboquant-git')
  conflicts=('ollama' 'ollama-turboquant-git' 'ollama-turboquant-vulkan-git' 'ollama-turboquant-rocm-git')

  _package_common

  cd "$srcdir/ollama"
  DESTDIR="$srcdir/staging-cuda" cmake --install build-cuda
  mkdir -p "$pkgdir/usr/lib/ollama"
  if [ -d "$srcdir/staging-cuda/usr/lib/ollama" ]; then
    cp -dr --no-preserve=ownership "$srcdir/staging-cuda/usr/lib/ollama/"* "$pkgdir/usr/lib/ollama/"
  fi
  if [ -f "build-cuda/llama-server-local/bin/libggml-cuda.so" ]; then
    cp build-cuda/llama-server-local/bin/libggml-cuda.so "$pkgdir/usr/lib/ollama/"
  fi
}

package_ollama-turboquant-vulkan-git() {
  pkgdesc="Create, run and share large language models (LLMs) - TurboQuant fork with Vulkan"
  depends+=('vulkan-driver' 'vulkan-icd-loader')
  provides=('ollama' 'ollama-turboquant-git')
