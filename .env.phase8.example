# Phase 8: Consolidated Settings - Example Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development  # Options: development, staging, production

# ============================================================================
# API SETTINGS (Phase 8: APISettings)
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false  # Set to true for development
API_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
API_RATE_LIMIT_REQUESTS=100  # Requests per minute
API_RATE_LIMIT_WINDOW=60     # Window in seconds

# ============================================================================
# DATABASE SETTINGS (Phase 8: DatabaseSettings)
# ============================================================================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=ollama
DATABASE_PASSWORD=secure_password_here  # Phase 8: SecretStr (masked in logs)
DATABASE_NAME=ollama
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_SSL_MODE=prefer
DATABASE_TIMEOUT=30

# Phase 8: Auto-generated URL (optional - generated from above if not set)
# DATABASE_URL=postgresql://ollama:secure_password_here@postgres:5432/ollama

# ============================================================================
# REDIS SETTINGS (Phase 8: RedisSettings)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_here  # Phase 8: SecretStr (masked in logs)
REDIS_DB=0
REDIS_SSL=false
REDIS_SOCKET_TIMEOUT=5

# Phase 8: Auto-generated URL (optional - generated from above if not set)
# REDIS_URL=redis://:redis_password_here@redis:6379/0

# ============================================================================
# OLLAMA SETTINGS (Phase 8: OllamaSettings)
# ============================================================================
OLLAMA_BASE_URL=http://ollama:11434  # Phase 8: URL validation
OLLAMA_TIMEOUT=300.0
OLLAMA_MODEL_TIMEOUT=600.0
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_MODELS=["llama3.2", "mistral", "codellama"]

# ============================================================================
# VECTOR DATABASE SETTINGS (Phase 8: VectorDBSettings - Qdrant)
# ============================================================================
VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333
VECTOR_DB_API_KEY=  # Phase 8: SecretStr (optional for local)
VECTOR_DB_COLLECTION_NAME=ollama_documents
VECTOR_DB_VECTOR_SIZE=384

# Phase 8: Auto-generated URL (optional - generated from above if not set)
# VECTOR_DB_URL=http://qdrant:6333

# ============================================================================
# GCP SETTINGS (Phase 8: GCPSettings)
# ============================================================================
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SECRET_MANAGER_ENABLED=false  # Enable for production
GCP_USE_WORKLOAD_IDENTITY=false   # Enable for GKE

# ============================================================================
# MONITORING SETTINGS (Phase 8: MonitoringSettings)
# ============================================================================
MONITORING_PROMETHEUS_ENABLED=true
MONITORING_JAEGER_ENABLED=true
MONITORING_JAEGER_HOST=jaeger
MONITORING_JAEGER_PORT=6831
MONITORING_LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# LEGACY SETTINGS (for backward compatibility)
# ============================================================================
# These will be deprecated in favor of Phase 8 consolidated settings
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info
PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["X-Request-ID"]
TRUSTED_HOSTS=

# Firebase OAuth (optional)
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

# ============================================================================
# PHASE 6: RATE LIMITING (Handled by Phase 8 APISettings)
# ============================================================================
# Rate limiting now uses:
# - API_RATE_LIMIT_REQUESTS (requests per window)
# - API_RATE_LIMIT_WINDOW (window in seconds)

# ============================================================================
# PHASE 7: PERFORMANCE MONITORING
# ============================================================================
# SLO targets are defined in code (ollama/monitoring/dashboards.py)
# - API response P95: <500ms
# - Inference P95: <5s
# - Inference P99: <10s
# - Error rate: <1%
# - Cache hit rate: >70%

# ============================================================================
# NOTES
# ============================================================================
# 1. Phase 8 settings use Pydantic validation - invalid values will fail at startup
# 2. Secrets (passwords, API keys) are masked in logs using SecretStr
# 3. URLs are auto-generated from component settings if not explicitly set
# 4. GCP Secret Manager can override all settings when enabled
# 5. Environment variable prefix for all settings: (none) - uses direct names
