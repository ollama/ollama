# GitHub API Integration - Environment Configuration Template
# 
# Copy this file to .env locally and fill in your values
# IMPORTANT: .env files are gitignored - NEVER commit sensitive values
# 
# For CI/CD, use GitHub Repository Secrets instead:
# Settings → Secrets and variables → Actions → New repository secret

# ============================================================================
# GitHub API Authentication
# ============================================================================

# Personal Access Token (PAT) for GitHub API authentication
# Get this from: https://github.com/settings/tokens
# Select scopes: repo, write:repo_hook, admin:repo_hook, workflow
# SECURITY: This is sensitive - never commit or share
GITHUB_TOKEN=ghp_your_personal_access_token_here

# GitHub username (repository owner)
GITHUB_USER=kushin77

# GitHub repository name
GITHUB_REPO=ollama

# ============================================================================
# Webhook Configuration (for incoming GitHub events)
# ============================================================================

# Secret used to verify incoming webhook payloads (HMAC-SHA256)
# This should be a random 32+ character string
# Set this value when creating webhooks in GitHub repository settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here_min_32_chars

# Webhook server port (for local testing)
GITHUB_WEBHOOK_PORT=8080

# ============================================================================
# GitHub App Settings (optional - for advanced automation)
# ============================================================================

# GitHub App ID
# Get from: https://github.com/settings/apps/your-app
GITHUB_APP_ID=

# GitHub App Installation ID
# For a specific repository installation
GITHUB_APP_INSTALLATION_ID=

# GitHub App Private Key (path to file)
# SECURITY: Store securely, never commit
GITHUB_APP_PRIVATE_KEY_PATH=

# ============================================================================
# OAuth Configuration (optional - for web applications)
# ============================================================================

# OAuth Client ID
GITHUB_OAUTH_CLIENT_ID=

# OAuth Client Secret
# SECURITY: This is sensitive - use GitHub Secrets in CI/CD
GITHUB_OAUTH_CLIENT_SECRET=

# ============================================================================
# API Rate Limiting & Behavior
# ============================================================================

# Rate limit requests per second (to avoid hitting GitHub's limits)
# GitHub allows 5000 requests/hour = ~1.4 requests/second
# Recommended: 0.8 requests/sec to be safe
GITHUB_API_RATE_LIMIT=0.8

# Retry attempts for failed API calls
GITHUB_API_RETRY_ATTEMPTS=3

# Retry backoff multiplier (exponential backoff)
GITHUB_API_RETRY_BACKOFF=2

# Request timeout in seconds
GITHUB_API_TIMEOUT=30

# ============================================================================
# Logging & Monitoring
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable audit logging of API operations
ENABLE_AUDIT_LOG=true

# Audit log file path
AUDIT_LOG_PATH=./logs/github-api-audit.log

# ============================================================================
# Development Configuration
# ============================================================================

# Enable debug mode (verbose logging)
DEBUG=false

# GitHub API Base URL (for testing with GitHub Enterprise)
GITHUB_API_BASE_URL=https://api.github.com

# ============================================================================
# CI/CD Environment Variables (set by GitHub Actions automatically)
# ============================================================================

# These are set automatically in GitHub Actions workflows
# GITHUB_TOKEN        - Automatic token for current workflow
# GITHUB_REPOSITORY   - Owner/repo (e.g., kushin77/ollama)
# GITHUB_EVENT_NUMBER - Pull request or issue number
# GITHUB_EVENT_ACTION - Action that triggered the workflow
# GITHUB_ACTOR        - Username of person triggering workflow

# ============================================================================
# Setup Instructions
# ============================================================================
# 
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your values:
#    - Get GITHUB_TOKEN from https://github.com/settings/tokens
#    - Generate GITHUB_WEBHOOK_SECRET (random 32+ chars)
#
# 3. Load environment:
#    source .env
#
# 4. Verify setup:
#    echo $GITHUB_TOKEN
#    curl -H "Authorization: token $GITHUB_TOKEN" \
#         https://api.github.com/rate_limit
#
# 5. For CI/CD:
#    - Go to Repository Settings → Secrets and variables → Actions
#    - Add each secret as a repository secret
#    - Reference in workflows with ${{ secrets.SECRET_NAME }}
#
# ============================================================================
# Security Reminders
# ============================================================================
#
# ✅ DO:
# - Store sensitive values in environment variables
# - Rotate tokens every 90 days
# - Use .gitignore for .env files
# - Use GitHub Secrets in CI/CD workflows
# - Verify webhook signatures
#
# ❌ DON'T:
# - Commit .env files to git
# - Share tokens via email or chat
# - Hardcode tokens in source code
# - Use overly broad token scopes
# - Log full token values
#
# ============================================================================
# Documentation
# ============================================================================
#
# - GitHub API Secrets Policy: GITHUB_API_SECRETS_POLICY.md
# - Quick Start Guide: GITHUB_API_QUICKSTART.md
# - File Instructions: .github/instructions/github-api-secrets.instructions.md
# - GitHub API Docs: https://docs.github.com/en/rest
#
