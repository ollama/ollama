# ============================================================================
# OLLAMA DEVELOPMENT ENVIRONMENT - Local Development Only
# ============================================================================
# MANDATE: All development MUST use real IP or DNS - NEVER localhost/127.0.0.1
# Get your IP: REAL_IP=$(hostname -I | awk '{print $1}')  # Linux
#              REAL_IP=$(ipconfig getifaddr en0)           # macOS
# ============================================================================

# ============================================================================
# DEVELOPMENT MODE
# ============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# ============================================================================
# SERVER CONFIGURATION - Use real IP/DNS in development
# ============================================================================
# ✅ CORRECT: Get real IP and use it
# REAL_IP=$(hostname -I | awk '{print $1}')
# PUBLIC_API_URL=http://$REAL_IP:8000
#
# ✅ CORRECT: Use DNS name if configured
# PUBLIC_API_URL=http://dev-ollama.internal:8000
#
# ❌ WRONG: Never use localhost in development
# PUBLIC_API_URL=http://localhost:8000
# PUBLIC_API_URL=http://127.0.0.1:8000
#
PUBLIC_API_URL=http://dev-ollama.internal:8000

OLLAMA_HOST=0.0.0.0:8000
OLLAMA_PORT=8000

# ============================================================================
# DATABASE - Use Docker service names (internal communication only)
# ============================================================================
# ✅ CORRECT: Use 'postgres' service name
DATABASE_URL=postgresql://ollama:changeme@postgres:5432/ollama
DATABASE_POOL_SIZE=5
DATABASE_TIMEOUT=30

# ============================================================================
# REDIS CACHE - Use Docker service names (internal communication only)
# ============================================================================
# ✅ CORRECT: Use 'redis' service name, NOT localhost
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# QDRANT VECTOR DB - Use Docker service names (internal communication only)
# ============================================================================
# ✅ CORRECT: Use 'qdrant' service name, NOT localhost
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ============================================================================
# OLLAMA INFERENCE - Use Docker service names (internal communication only)
# ============================================================================
# ✅ CORRECT: Use 'ollama' service name, NOT localhost
OLLAMA_BASE_URL=http://ollama:11434

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
OLLAMA_MODELS_PATH=/models
OLLAMA_CACHE_SIZE=20G
OLLAMA_GPU_MEMORY=8000

# ============================================================================
# GPU/CUDA CONFIGURATION
# ============================================================================
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
TORCH_DEVICE_BATCH_SIZE=1

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

LOG_FORMAT=json

# ============================================================================
# SECURITY - Development relaxed, Production strict
# ============================================================================
API_KEY_AUTH_ENABLED=false

# Development CORS: Allow real IP/DNS access
# Example: http://192.168.1.100:3000, http://dev-ollama.internal:3000
CORS_ORIGINS=["https://elevatediq.ai","http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["Content-Type","X-RateLimit-Limit","X-RateLimit-Remaining"]

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# JWT/AUTHENTICATION
# ============================================================================
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# IMPORTANT DEVELOPMENT NOTES
# ============================================================================
# 1. Docker Service Names (INTERNAL COMMUNICATION):
#    - postgres (NOT localhost:5432)
#    - redis (NOT localhost:6379)
#    - qdrant (NOT localhost:6333)
#    - ollama (NOT localhost:11434)
#    - jaeger (NOT localhost:6831)
#
# 2. PUBLIC_API_URL (EXTERNAL/CLIENT ACCESS):
#    - Use REAL IP: http://192.168.1.100:8000
#    - Use DNS: http://dev-ollama.internal:8000
#    - NEVER use localhost or 127.0.0.1
#
# 3. Why This Matters:
#    - Ensures feature parity between development and production
#    - Catches network-specific bugs before production
#    - Validates DNS resolution and service discovery
#    - Enables team collaboration on local deployments
#    - Simulates load balancer routing behavior
# ============================================================================
