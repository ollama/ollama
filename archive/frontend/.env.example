# Ollama Frontend Environment Variables
# Copy to .env.local and configure for your environment

# API Configuration (MANDATORY)
NEXT_PUBLIC_API_URL=https://elevatediq.ai/ollama
NEXT_PUBLIC_WS_URL=wss://elevatediq.ai/ollama

# Firebase OAuth Configuration (MANDATORY)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Application Configuration
NEXT_PUBLIC_APP_NAME=Ollama Elite AI
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=production

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_DOCUMENTS=true
NEXT_PUBLIC_ENABLE_EMBEDDINGS=true
NEXT_PUBLIC_ENABLE_TRAINING=false

# Analytics (Optional)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Development Only (DO NOT USE IN PRODUCTION)
# NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
