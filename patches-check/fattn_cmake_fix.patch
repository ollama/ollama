diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -95,6 +95,12 @@ if(CMAKE_HIP_COMPILER)
     message(STATUS "HIP support enabled")

