     if(NOT AMDGPU_TARGETS)
         list(FILTER AMDGPU_TARGETS INCLUDE REGEX "^gfx(900|94[012]|101[02]|1030|110[012]|120[01])$")
     elseif(WIN32 AND WINDOWS_AMDGPU_TARGETS_EXCLUDE_REGEX)
@@ -102,6 +108,15 @@ if(CMAKE_HIP_COMPILER)
     endif()
 endif()

+# ULTIMATE: TurboQuant KV cache compression
+if(GGML_TURBOQUANT)
+    message(STATUS "TurboQuant KV cache compression enabled")
+    add_compile_definitions(GGML_TURBOQUANT)
+    include_directories(${CMAKE_SOURCE_DIR}/ggml_turboquant)
+    link_directories(${CMAKE_SOURCE_DIR}/ggml_turboquant)
+    target_link_libraries(ggml PRIVATE ggml_turboquant)
+    target_link_libraries(llama PRIVATE ggml_turboquant)
+endif()
