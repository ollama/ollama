+	if cacheTypeV := os.Getenv("OLLAMA_CACHE_TYPE_V"); cacheTypeV != "" {
+		os.Setenv("LLAMA_CACHE_TYPE_V", cacheTypeV)
+	}
+	
+	// Or from model options
+	if opts.CacheTypeK != "" {
+		os.Setenv("LLAMA_CACHE_TYPE_K", opts.CacheTypeK)
+	}
+	if opts.CacheTypeV != "" {
+		os.Setenv("LLAMA_CACHE_TYPE_V", opts.CacheTypeV)
+	}
+	
 	return nil
 }
