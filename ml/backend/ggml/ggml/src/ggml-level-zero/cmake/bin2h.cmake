# bin2h.cmake - convert a binary file to a C unsigned char array header.
# Usage: cmake -D INPUT=<path> -D OUTPUT=<path> -D VARNAME=<name> -P bin2h.cmake
cmake_minimum_required(VERSION 3.21)
if(NOT INPUT OR NOT OUTPUT OR NOT VARNAME)
    message(FATAL_ERROR "bin2h.cmake requires INPUT, OUTPUT, VARNAME")
endif()
file(READ "${INPUT}" _hex_content HEX)
string(LENGTH "${_hex_content}" _hex_len)
math(EXPR _byte_count "${_hex_len} / 2")
set(_bytes "")
set(_col 0)
math(EXPR _last "${_hex_len} - 2")
foreach(_pos RANGE 0 ${_last} 2)
    string(SUBSTRING "${_hex_content}" ${_pos} 2 _byte)
    if(_col GREATER 0)
        string(APPEND _bytes ",")
    endif()
    if(_col EQUAL 16)
        string(APPEND _bytes "\n    ")
        set(_col 0)
    endif()
    string(APPEND _bytes "0x${_byte}")
    math(EXPR _col "${_col} + 1")
endforeach()
file(WRITE "${OUTPUT}"
    "// Auto-generated by bin2h.cmake - do not edit.\n"
    "static const unsigned char ${VARNAME}[] = {\n    ${_bytes}\n};\n"
    "static const unsigned int  ${VARNAME}_size = ${_byte_count};\n"
)
message(STATUS "bin2h: wrote ${_byte_count} bytes -> ${OUTPUT}")
