{{- if .Messages }}
{{- range .Messages }}
{{- if eq .Role "user" }}[INST] {{ if and $.System (eq (index $.Messages (sub (len $.Messages) 1)) .) }}{{ $.System }}
{{ end }}{{ .Content }}
{{- else if eq .Role "assistant" }}[/INST] {{ .Content }}</s>
{{- end }}
{{- end }}[/INST]
{{- else }}[INST] {{ if .System }}{{ .System }} {{ end }}{{ .Prompt }} [/INST] {{ .Response }}
{{- end }}